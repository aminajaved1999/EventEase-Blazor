@page "/session"
@using Blazored.LocalStorage
@using Microsoft.AspNetCore.Components
@inject ILocalStorageService localStorage

<h3>User Session</h3>

@if (string.IsNullOrEmpty(userName))
{
    <p>Please log in.</p>
    <button @onclick="Login">Login as User</button>
}
else
{
    <p>Welcome, @userName!</p>
    <button @onclick="Logout">Logout</button>
}

@code {
    private string? userName;  // Made userName nullable

    protected override async Task OnInitializedAsync()
    {
        // Try to retrieve userName from local storage on initialization
        userName = await localStorage.GetItemAsync<string>("userName");
    }

    private async Task Login()
    {
        userName = "JohnDoe";  // Simulating user login
        await localStorage.SetItemAsync("userName", userName);
    }

    private async Task Logout()
    {
        userName = null;
        await localStorage.RemoveItemAsync("userName");
    }
}
