@page "/event"
@using EventEase.Models
@inject NavigationManager Navigation

<div class="event-card">
    <h3>@EventModel.EventName</h3>
    <p>@EventModel.EventDate.ToString("MMMM dd, yyyy")</p>
    <p>@EventModel.Location</p>
    <p>@EventModel.Description</p>
    <button @onclick="EditEvent">Edit Event</button>
</div>

@code {
    private EventModel EventModel { get; set; } = new EventModel
    {
        EventName = "Default Event Name",
        EventDate = DateTime.Now, // Set a default date
        Location = "Default Location",
        Description = "Default Event Description" // Initialize Description
    };

    private void EditEvent()
    {
        // Navigate to the EditEvent page with the EventId (assuming EventId is available in EventModel)
        Navigation.NavigateTo($"/edit-event/{EventModel.EventId}");
    }
}
