@page "/edit-event/{EventId}"
@using EventEase.Models
@inject NavigationManager Navigation

<h3>Edit Event</h3>

<EditForm Model="EventModel" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div>
        <label for="EventName">Event Name</label>
        <InputText id="EventName" @bind-Value="EventModel.EventName" />
    </div>
    <div>
        <label for="EventDate">Event Date</label>
        <InputDate id="EventDate" @bind-Value="EventModel.EventDate" />
    </div>
    <div>
        <label for="Location">Location</label>
        <InputText id="Location" @bind-Value="EventModel.Location" />
    </div>
    <div>
        <label for="Description">Description</label>
        <InputTextArea id="Description" @bind-Value="EventModel.Description" />
    </div>

    <button type="submit">Save Changes</button>
</EditForm>

<button @onclick="CancelEdit">Cancel</button>

@code {
    [Parameter] public int EventId { get; set; }
    private EventModel EventModel { get; set; } = new EventModel
    {
        EventName = string.Empty,
        Location = string.Empty,
        Description = string.Empty
    };

    protected override async Task OnInitializedAsync()
    {
        // Load the event data based on EventId (you would get this from a service or API)
        EventModel = await LoadEventData(EventId);
    }

    private Task<EventModel> LoadEventData(int eventId)
    {
        // For example, returning a default event for now. Replace with actual data loading logic.
        return Task.FromResult(new EventModel
        {
            EventName = "Sample Event",
            EventDate = DateTime.Now,
            Location = "Sample Location",
            Description = "Sample Description"
        });
    }

    private void HandleValidSubmit()
    {
        // Logic to save the updated event (e.g., via API or database)
        Console.WriteLine("Event saved successfully.");
        Navigation.NavigateTo("/event"); // Navigate back to the event page after saving
    }

    private void CancelEdit()
    {
        Navigation.NavigateTo("/event"); // Navigate back to the event page without saving
    }
}
